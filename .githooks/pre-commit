#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v gofmt >/dev/null 2>&1; then
	echo "pre-commit: gofmt not found on PATH" >&2
	exit 1
fi

staged_go_files="$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)"
if [ -z "$staged_go_files" ]; then
	exit 0
fi

unformatted="$(printf '%s\n' "$staged_go_files" | gofmt -l)"
if [ -n "$unformatted" ]; then
	echo "pre-commit: formatting staged Go files with gofmt..."
	printf '%s\n' "$unformatted" | gofmt -w
	printf '%s\n' "$unformatted" | xargs git add
fi

unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
	echo "pre-commit: unformatted Go files remain (same check as CI):" >&2
	echo "$unformatted" >&2
	echo "Run: gofmt -w ." >&2
	exit 1
fi
