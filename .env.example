HTTP_ADDR=:8088
# For host `go run` with docker-compose.dev.yml (postgres exposed on 5433).
# Ignored when using full compose — discovery service uses postgres:5432 internally.
DISCOVERY_PG_USER=discovery
DISCOVERY_PG_PASSWORD=discovery
DISCOVERY_PG_DB=discovery
DATABASE_URL=postgres://discovery:discovery@localhost:5433/discovery?sslmode=disable
REDIS_URL=

 # run `openssl rand -hex 32` to generate a random secret
CRON_SECRET=dev-cron-secret
LEADERBOARD_REFRESH_INTERVAL_MS=60000
MEMBERSHIP_STRATEGY=union
QUERY_CACHE_TTL_MS=120000
MAX_TOP_N=1000

# ClickHouse (direct)
CLICKHOUSE_URL=https://clickhouse.example.com
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# Or gateway proxy URL (NaaP /api/v1/gw/clickhouse-query/query)
# CLICKHOUSE_GATEWAY_URL=http://localhost:3000/api/v1/gw/clickhouse-query

SUBGRAPH_URL=https://api.thegraph.com
SUBGRAPH_ID=FE63YgkzcpVocxdCEyEYbvjYqEf2kb1A6daMYRxmejYC

# On-chain serviceURI registry manifest probing (subgraph -> manifest GET)
REGISTRY_MANIFEST_REFRESH_ENABLED=true
REGISTRY_MANIFEST_TIMEOUT_MS=5000
REGISTRY_MANIFEST_MAX_CONCURRENCY=25
REGISTRY_MANIFEST_MAX_ORCHESTRATORS=1000
AI_SERVICE_REGISTRY_RPC_URL=https://arb1.arbitrum.io/rpc
AI_SERVICE_REGISTRY_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5

DISCOVER_API_URL=https://naap-api.cloudspe.com/v1/discover/orchestrators
PRICING_API_URL=

# Optional: remote signer /discover-orchestrators as additional source
REMOTE_SIGNER_URL=

# Probe each known orch's GET /discovery for live-runner app capabilities
ORCH_DISCOVERY_REFRESH_ENABLED=true
ORCH_DISCOVERY_TIMEOUT_MS=5000
ORCH_DISCOVERY_MAX_CONCURRENCY=25
ORCH_DISCOVERY_MAX_ORCHESTRATORS=1000

# Set false in production (use deploy/cron Railway service instead of per-replica refresh)
REFRESH_ON_STARTUP=false
